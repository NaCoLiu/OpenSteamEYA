<Page
    x:Class="SteamEyaWinUI.Pages.PersonalizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto"
        Padding="32,24,32,16">
        <StackPanel MaxWidth="880" Spacing="16" HorizontalAlignment="Left">
            <StackPanel Spacing="4">
                <TextBlock
                    Text="{x:Bind Strings.Get('Personalization_Title'), Mode=OneWay}"
                    Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock
                    Text="{x:Bind Strings.Get('Personalization_Subtitle'), Mode=OneWay}"
                    Style="{StaticResource PageSubtitleTextStyle}" />
            </StackPanel>

            <!-- 昵称 -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Text="{x:Bind Strings.Get('Personalization_Nickname_Section'), Mode=OneWay}"
                            Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock
                            x:Name="NicknameCounter"
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                    <TextBlock
                        Text="{x:Bind Strings.Get('Personalization_Nickname_Desc'), Mode=OneWay}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                    <TextBox
                        x:Name="NicknameBox"
                        HorizontalAlignment="Stretch"
                        MaxLength="64"
                        PlaceholderText="{x:Bind Strings.Get('Personalization_Nickname_Placeholder'), Mode=OneWay}"
                        IsSpellCheckEnabled="False"
                        TextChanged="NicknameBox_TextChanged" />
                </StackPanel>
            </Border>

            <!-- 头像：仿 Steam——整图叠可拖动 / 缩放的方形选框。左裁剪台、右多尺寸预览 + 上传 + 保存，
                 两栏排布让整页无需滚动。 -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock
                        Text="{x:Bind Strings.Get('Personalization_Avatar_Section'), Mode=OneWay}"
                        Style="{StaticResource SectionTitleTextStyle}" />

                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 左：裁剪台（整图 + 方形选框覆盖层） -->
                        <Border x:Name="CropStage" Grid.Column="0" Width="420" Height="320" CornerRadius="8"
                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Padding="16">
                            <Grid>
                                <Grid x:Name="CropArea" Width="388" Height="288" Visibility="Collapsed">
                                    <Image x:Name="CropImage"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Stretch="Fill">
                                        <Image.RenderTransform>
                                            <CompositeTransform x:Name="CropImageTransform" />
                                        </Image.RenderTransform>
                                    </Image>
                                    <Canvas x:Name="CropOverlay" Width="388" Height="288" Background="Transparent"
                                            PointerPressed="CropOverlay_PointerPressed"
                                            PointerMoved="CropOverlay_PointerMoved"
                                            PointerReleased="CropOverlay_PointerReleased"
                                            PointerCanceled="CropOverlay_PointerReleased"
                                            PointerWheelChanged="CropOverlay_PointerWheelChanged" />
                                </Grid>
                                <StackPanel x:Name="CropPlaceholder"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                    <FontIcon Glyph="&#xE91B;" FontSize="28" HorizontalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{x:Bind Strings.Get('Personalization_Avatar_NoImage'), Mode=OneWay}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center" TextAlignment="Center"
                                               TextWrapping="Wrap" MaxWidth="240" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 右：多尺寸预览 + 上传 + 保存 -->
                        <StackPanel Grid.Column="1" Spacing="14" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <StackPanel Spacing="6">
                                    <Border Width="100" Height="100" CornerRadius="4"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                        <Image x:Name="Preview184" Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock Text="184px" HorizontalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Spacing="6" VerticalAlignment="Bottom">
                                    <Border Width="64" Height="64" CornerRadius="4"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                        <Image x:Name="Preview64" Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock Text="64px" HorizontalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Spacing="6" VerticalAlignment="Bottom">
                                    <Border Width="32" Height="32" CornerRadius="4"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                        <Image x:Name="Preview32" Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock Text="32px" HorizontalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <Button x:Name="PickImageButton" HorizontalAlignment="Left" Click="PickImageButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xEB9F;" FontSize="16" />
                                    <TextBlock Text="{x:Bind Strings.Get('Personalization_Btn_PickImage'), Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{x:Bind Strings.Get('Personalization_Avatar_UploadHint'), Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" FontSize="12" MaxWidth="320" />
                            <TextBlock Text="{x:Bind Strings.Get('Personalization_Avatar_CropHint'), Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" FontSize="12" MaxWidth="320" />

                            <Button x:Name="SaveAvatarButton" HorizontalAlignment="Left"
                                    Style="{StaticResource AccentButtonStyle}" IsEnabled="False"
                                    Click="SaveAvatarButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE74E;" FontSize="16" />
                                    <TextBlock Text="{x:Bind Strings.Get('Personalization_Btn_SaveAvatar'), Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <InfoBar x:Name="PageInfoBar" IsClosable="True" IsOpen="False" />
        </StackPanel>
    </ScrollViewer>
</Page>
